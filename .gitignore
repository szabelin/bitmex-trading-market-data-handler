 # Created by https://www.toptal.com/developers/gitignore/api/java
 # Edit at https://www.toptal.com/developers/gitignore?templates=java

 ### Java ###
 # Compiled class file
 *.class

 # Log file
 *.log

 # BlueJ files
 *.ctxt

 # Mobile Tools for Java (J2ME)
 .mtj.tmp/

 # Package Files #
 *.jar
 *.war
 *.nar
 *.ear
 *.zip
 *.tar.gz
 *.rar

 # virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
 hs_err_pid*
 replay_pid*


 .DS_Store
 /data/

 # IDE & OS
 .idea/
 *.iml
 *.ipr
 *.iws

 # Gradle
 .gradle/
 build/
 *.lock
 !gradle-wrapper.jar

 # IntelliJ execution history
 executionHistory.bin
 executionHistory.lock

 # Build output
 /build/
 buildOutputCleanup.lock
 checksums.lock

 # Test artifacts
 **/test-output/
 **/test-results/
 **/reports/
 **/test/css/

 # Log and system files
 *.tmp
 *.probe

 .gradle/**/checksums.lock
